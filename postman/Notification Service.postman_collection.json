{
  "info": {
    "name": "Notification Service",
    "description": "Postman collection for the Laravel notification microservice.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "lastBatchId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create transactional SMS batch",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Idempotency-Key",
            "value": "postman-transactional-001"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channel\": \"sms\",\n  \"priority\": \"transactional\",\n  \"message\": \"Ваш код доступа: 1234\",\n  \"subscriber_ids\": [1]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/notification-batches",
          "host": ["{{baseUrl}}"],
          "path": ["api", "notification-batches"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Batch created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('lastBatchId', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create marketing email batch",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Idempotency-Key",
            "value": "postman-marketing-001"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channel\": \"email\",\n  \"priority\": \"marketing\",\n  \"message\": \"Маркетинговая рассылка\",\n  \"subscriber_ids\": [2, 3, 4, 5, 6, 7, 8, 9]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/notification-batches",
          "host": ["{{baseUrl}}"],
          "path": ["api", "notification-batches"]
        }
      }
    },
    {
      "name": "Get seeded demo batch",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/notification-batches/019eb82a-1605-7392-ba67-7287397244fa",
          "host": ["{{baseUrl}}"],
          "path": ["api", "notification-batches", "019eb82a-1605-7392-ba67-7287397244fa"]
        }
      }
    },
    {
      "name": "Get last created batch",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/notification-batches/{{lastBatchId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "notification-batches", "{{lastBatchId}}"]
        }
      }
    },
    {
      "name": "Get subscriber notification history",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/subscribers/1/notifications",
          "host": ["{{baseUrl}}"],
          "path": ["api", "subscribers", "1", "notifications"]
        }
      }
    },
    {
      "name": "Validation error: missing Idempotency-Key",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channel\": \"sms\",\n  \"priority\": \"transactional\",\n  \"message\": \"Missing idempotency key\",\n  \"subscriber_ids\": [1]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/notification-batches",
          "host": ["{{baseUrl}}"],
          "path": ["api", "notification-batches"]
        }
      }
    },
    {
      "name": "Not found: missing subscriber",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/subscribers/999/notifications",
          "host": ["{{baseUrl}}"],
          "path": ["api", "subscribers", "999", "notifications"]
        }
      }
    }
  ]
}
